# .gcloudignore - Controls what gets uploaded to Cloud Build
# Based on .gitignore but INCLUDES product images for deployment

node_modules
dist
.DS_Store
server/public
vite.config.ts.*
*.tar.gz
tmpclaude-*

# Mopar scraper
mopar-scraper/.env
mopar-scraper/data/progress.db
mopar-scraper/data/images/
mopar-scraper/data/output/

# Environment files
.env
.env.*

# Scrape data dumps (large files, regenerated by scripts)
data/*.json
data/*.xml
data/*.png
data/sync-results/

# NOTE: attached_assets/product_images/ is NOT excluded here
# (unlike .gitignore) so images are included in Cloud Run deploys

# Dealer pricing spreadsheets (sensitive cost data)
attached_assets/*.xls
attached_assets/adam_new/

# Debug/misc binary assets
attached_assets/*.pdf
attached_assets/*.zip
attached_assets/image_*.png

# Replit local state
.local/
.config/

# Logs
*.log

# Git (not needed in build)
.git
